# ── Vercel (Next.js frontend) environment variables ──────────────────────────
# Add these in Vercel → Project Settings → Environment Variables

# URL of the Railway Python backend (set after Railway deployment)
NEXT_PUBLIC_API_URL=https://your-scout-api.up.railway.app

# Anthropic — used by Next.js API routes (/api/chat/*)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Twilio — used by /api/notify/register and /api/notify/whatsapp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+17789009548
# Optional: Twilio WhatsApp sender (e.g. whatsapp:+14155238886 for sandbox)
TWILIO_WHATSAPP_NUMBER=

# Resend — weekly email digest (/api/cron/email-digest). Free tier: 3k emails/month.
# Sign up at resend.com, verify your sending domain, then add the key here.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cron security — set this in Vercel env vars. Vercel will send it as
# Authorization: Bearer <CRON_SECRET> on all cron requests.
CRON_SECRET=your-random-secret-here
